DATABASE_URL=""
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# JWT
JWT_ACCESS_SECRET="change-me-in-.env"
JWT_ACCESS_EXPIRES_IN="15m"

# Cloudinary 
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email thông báo form liên hệ — gửi qua Resend HTTPS API 
RESEND_API_KEY=""
# Địa chỉ gửi — phải thuộc domain đã verify ở Resend, hoặc onboarding@resend.dev
# khi test.
MAIL_FROM=""
# Nơi nhận email báo có lead mới. Bắt buộc phải đặt.
CONTACT_NOTIFY_TO=""

# Origin của Admin SPA — dùng dựng link trong email lời mời thiết lập tài khoản.
# Biến KHÔNG bí mật, chỉ ở backend (không thêm tiền tố VITE_/NEXT_PUBLIC_).
# Bắt buộc HTTPS ở production; cho phép http://localhost khi dev/test. Bỏ trống
# hoặc sai định dạng → email lời mời tự bỏ qua (degrade an toàn).
ADMIN_APP_URL="http://localhost:5174"

# Sentry error tracking (task →5) — DSN của project Sentry riêng cho backend.
# Bỏ trống → không init, app chạy bình thường. DSN là khóa ingest-only (không
# đọc được dữ liệu), nhưng theo quy ước vẫn giữ server-side.
SENTRY_DSN=""
