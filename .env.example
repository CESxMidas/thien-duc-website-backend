# PostgreSQL — xem docs/CAU-HOI-CAN-XAC-NHAN.md câu 11 (nhà cung cấp hosting chưa chốt)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/thien_duc?schema=public"

PORT=3001
CORS_ORIGIN="http://localhost:3000"

# JWT
JWT_ACCESS_SECRET="change-me-in-.env"
JWT_ACCESS_EXPIRES_IN="15m"

# Cloudinary — cloud name công khai (nằm trong URL ảnh); key/secret lấy ở
# Dashboard → API Keys, role Master Admin. Chỉ dùng ở backend, không lộ ra FE.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email thông báo form liên hệ — gửi qua Resend HTTPS API (nhà cung cấp duy
# nhất; chọn Resend vì Render chặn cổng SMTP outbound / IPv6 như Gmail SMTP).
# Thiếu bất kỳ biến bắt buộc nào (RESEND_API_KEY/MAIL_FROM/CONTACT_NOTIFY_TO) →
# email bị bỏ qua, lead vẫn được lưu bình thường (xem src/mail/mail.service.ts).
#
# API key lấy ở dashboard Resend.
RESEND_API_KEY=""
# Địa chỉ gửi — phải thuộc domain đã verify ở Resend, hoặc onboarding@resend.dev
# khi test.
MAIL_FROM=""
# Nơi nhận email báo có lead mới. Bắt buộc phải đặt.
CONTACT_NOTIFY_TO=""

# Sentry error tracking (task →5) — DSN của project Sentry riêng cho backend.
# Bỏ trống → không init, app chạy bình thường. DSN là khóa ingest-only (không
# đọc được dữ liệu), nhưng theo quy ước vẫn giữ server-side.
SENTRY_DSN=""
