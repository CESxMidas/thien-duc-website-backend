# PostgreSQL — xem docs/CAU-HOI-CAN-XAC-NHAN.md câu 11 (nhà cung cấp hosting chưa chốt)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/thien_duc?schema=public"

PORT=3001
CORS_ORIGIN="http://localhost:3000"

# JWT
JWT_ACCESS_SECRET="change-me-in-.env"
JWT_ACCESS_EXPIRES_IN="15m"

# Cloudinary — cloud name công khai (nằm trong URL ảnh); key/secret lấy ở
# Dashboard → API Keys, role Master Admin. Chỉ dùng ở backend, không lộ ra FE.
CLOUDINARY_CLOUD_NAME="thienduc"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMTP thông báo form liên hệ — xem câu 9 (email domain chính thức chưa có).
# Thiếu bất kỳ biến bắt buộc nào (HOST/USER/PASSWORD/FROM) → email bị bỏ qua,
# lead vẫn được lưu bình thường (xem src/mail/mail.service.ts).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="dautuxaydungthienduc@yahoo.com"
# Nơi nhận email báo có lead mới. Bỏ trống → gửi về chính SMTP_FROM.
CONTACT_NOTIFY_TO=""

# Sentry error tracking (task →5) — DSN của project Sentry riêng cho backend.
# Bỏ trống → không init, app chạy bình thường. DSN là khóa ingest-only (không
# đọc được dữ liệu), nhưng theo quy ước vẫn giữ server-side.
SENTRY_DSN=""
